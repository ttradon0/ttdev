# Infisical Configuration
# Get your token from https://app.infisical.com → Settings → Service Tokens

# Infisical Service Token (required)
INFISICAL_TOKEN=your-infisical-service-token-here

# Infisical Project ID (required)
# Find it in your project settings or URL: app.infisical.com/project/[PROJECT_ID]
INFISICAL_PROJECT_ID=your-project-id-here

# Infisical Environment (optional, defaults to 'dev')
INFISICAL_ENVIRONMENT=dev

# Fallback (optional - only if not using Infisical)
# DATABASE_URL=postgresql://...
